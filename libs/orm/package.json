{
  "name": "@rline/orm",
  "version": "1.12.0",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "keywords": [
    "orm"
  ],
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline@gmail.com",
    "url": "https://rbrightline.github.io"
  },
  "optionalDependencies": {
    "@nestjs/common": "^10.4.11",
    "@nestjs/config": "^3.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "typeorm": "^0.3.20"
  },
  "dependencies": {
    "@rline/property": "workspace:^",
    "@rline/type": "workspace:^",
    "@rline/validation": "workspace:^",
    "@swc/helpers": "~0.5.11"
  },
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "typings": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/orm/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/orm/dist",
          "main": "libs/orm/src/index.ts",
          "tsConfig": "libs/orm/tsconfig.lib.json"
        }
      },
      "test": {
        "executor": "@nx/vite:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "reportsDirectory": "../../coverage/libs/orm"
        }
      }
    },
    "name": "orm"
  }
}
