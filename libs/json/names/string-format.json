{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "StringFormat",
  "title": "String Format",

  "description": "String format like email, password, ip for validation",
  "enum": [
    "email",
    "password",
    "ip4",
    "ip6",
    "uuid",
    "jwt",
    "short",
    "long",
    "phone",
    "credit-card"
  ]
}
