{
  "name": "@rline/validation",
  "version": "2.1.0",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "keywords": [
    "validation"
  ],
  "repository": {
    "directory": ".",
    "type": "github",
    "url": "https://github.com/rbrightline/rbrightline.github.io/tree/main/libs/validation"
  },
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline@gmail.com",
    "url": "https://rbrightline.github.io"
  },
  "optionalDependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1"
  },
  "dependencies": {
    "@rline/type": "2.1.0",
    "@swc/helpers": "~0.5.11"
  },
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "typings": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/validation/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/validation/dist",
          "main": "libs/validation/src/index.ts",
          "tsConfig": "libs/validation/tsconfig.lib.json"
        }
      },
      "test": {
        "executor": "@nx/vite:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "reportsDirectory": "../../coverage/libs/validation"
        }
      }
    },
    "name": "validation"
  },
  "devDependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
